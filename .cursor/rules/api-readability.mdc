## Examples

### Firebase — Messaging Domain

`getMessagesFromFirebase` and `searchMessages` are the highest abstraction — they orchestrate lower-level helpers. `getUser` and `getConversation` are independent leaf operations.

```ts
class FirebaseAdmin {
  private db: admin.firestore.Firestore;
  private auth: admin.auth.Auth;

  constructor(adminInstance: typeof admin) { ... }

  // Independent leaf operations — no shared helpers, order among themselves doesn't matter
  async getUser(userId: string) { ... }

  async getConversation(conversationId: string) { ... }

  // Orchestrator — calls snapshot, isEmpty, snapshotToMessages
  async getMessagesFromFirebase(conversationId: string, limit = 50): Promise<FirebaseMessage[]> { ... }

  async getConversationSnapshot(conversationId: string, limit = 50): Promise<QuerySnapshot> { ... }

  isEmpty(snapshot: QuerySnapshot) { ... }

  snapshotToMessages(snapshot: QuerySnapshot): FirebaseMessage[] { ... }

  // Orchestrator — calls buildQuery, snapshotToMessages, filterByKeyword
  async searchMessages(conversationId: string, filters: MessageFilters) { ... }

  private buildQuery(conversationId: string, filters: MessageFilters) { ... }

  filterByKeyword(messages: FirebaseMessage[], keyword: string) { ... }
}

export const firebaseAdmin = new FirebaseAdmin(admin);
```

### Firestore — User Domain (Separate Class)

```ts
class UserService {
  private db: admin.firestore.Firestore;

  constructor(db: admin.firestore.Firestore) {
    this.db = db;
  }

  async getUserProfile(userId: string): Promise<UserProfile> { ... }

  async updateProfile(userId: string, updates: Partial<UserProfileUpdate>) { ... }

  async findUsersByUsername(searchTerm: string, limit = 10): Promise<UserSummary[]> { ... }

  async isUsernameAvailable(username: string): Promise<boolean> { ... }

  private toUserProfile(doc: DocumentSnapshot): UserProfile { ... }

  private toUserSummary(doc: DocumentSnapshot): UserSummary { ... }
}

export const userService = new UserService(admin.firestore());
```

### External API — Payments Domain

```ts
class PaymentService {
  private stripe: Stripe;

  constructor(stripeClient: Stripe) {
    this.stripe = stripeClient;
  }

  async createCheckoutSession(userId: string, plan: SubscriptionPlan): Promise<CheckoutSession> { ... }

  async handleWebhook(event: Stripe.Event) { ... }

  private async getOrCreateStripeCustomer(userId: string): Promise<string> { ... }

  private buildLineItems(plan: SubscriptionPlan) { ... }

  private toCheckoutSession(session: Stripe.Checkout.Session): CheckoutSession { ... }

  private async fulfillSubscription(session: Stripe.Checkout.Session) { ... }
}

export const paymentService = new PaymentService(stripe);
```
